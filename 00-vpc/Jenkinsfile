pipeline {
    agent {
        node {
            label 'robomart'
        }
    }

    environment {
        AWS_REGION = "us-east-1"
        AWS_CREDS = "aws-creds"
    }
    options{
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    stages {
        stage ('Init') {
            steps {
                script {
                    withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 00-vpc
                            terraform init
                        """
                    }
                }
            }
        }

        stage ('Plan') {
            steps {
                script {
                    withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 00-vpc
                            terraform plan
                        """
                    }
                }
            }
        }

        stage('Approve & Apply VPC') {
              steps {
                script {

                    // 🔐 Load email from Jenkins Secret Text credential
                    withCredentials([string(credentialsId: 'approval-email', variable: 'APPROVAL_EMAIL')]) {

                        // Convert to plain string + remove hidden newline/spaces
                        def cleanEmail = "${APPROVAL_EMAIL}".trim()

                        // 📧 Send approval email
                        emailext(
                            subject: "Approval required: Terraform Apply VPC",
                            body: """
                            Terraform VPC apply is waiting for approval.

                            Job: ${env.JOB_NAME}
                            Build: ${env.BUILD_NUMBER}
                            URL: ${env.BUILD_URL}

                            Please open Jenkins and approve the deployment.
                            """,
                                to: cleanEmail,
                                recipientProviders: []   // prevents Jenkins from filtering recipients
                        )
                    }

                    // ⛔ Pause pipeline until someone approves
                    input(
                        message: "Approve Terraform Apply for VPC?",
                        ok: "Apply"
                    )

                    // ☁️ Run Terraform after approval
                    withAWS(region: "${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 00-vpc
                            terraform apply --auto-approve
                        """
                    }

                }
            }
        }




        // stage ('Deploy'){
        //     input {
        //         message "Approve deployment?"
        //         ok "Deploy"
        //     }

        //     steps {
        //         script {
        //             withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
        //                 sh """
        //                     cd 00-vpc
        //                     terraform apply --auto-approve
        //                 """
        //             }
        //         }
        //     }
        // }
        stage('Trigger SG') {
            steps {
                build job: '10-sg', 
                wait: false,
                propagate: false
            }
        }
    }
    post {
        always {
            echo "Post Message after stages"
            cleanWs()
        }
        success {
            echo "Infra is success"
        }
        failure {
            echo "Infra is failure"
        }
    }
}