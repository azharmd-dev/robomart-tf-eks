pipeline {
    agent {
        node {
            label 'robomart'
        }
    }

        environment {
        AWS_REGION = "us-east-1"
        AWS_CREDS = "aws-creds"
    }

    stages {
        stage ('Init') {
            steps {
                script {
                    withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 90-eks
                            terraform init
                        """
                    }
                }
            }
        }

        stage ('Plan') {
            steps {
                script {
                    withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 90-eks
                            terraform plan
                        """
                    }
                }
            }
        }

        stage ('Deploy'){
            steps {
                script {
                    withAWS(region:"${AWS_REGION}", credentials: "${AWS_CREDS}") {
                        sh """
                            cd 90-eks
                            terraform apply --auto-approve
                        """
                    }
                }
            }
        }
    }
    post {
        always {
            echo "Post Message after stages"
            cleanWs()
        }
        success {
            echo "Infra is success"
        }
        failure {
            echo "Infra is failure"
        }
    }
}